# Supabase (development)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Tableo Platform Integration
TABLEO_APP_URL="https://app.tableo.com"
TABLEO_API_URL="https://app.tableo.com/api/restaurant"

# Auth (shared secrets with Tableo main app)
JWT_SECRET="your-64-char-random-secret-shared-with-tableo"
WEBHOOK_SECRET="your-64-char-random-secret-for-webhooks"

# Cron jobs
CRON_SECRET="your-cron-secret"

# Email (Resend - https://resend.com)
RESEND_API_KEY="re_your_resend_api_key"
NOTIFY_FROM_EMAIL="shifts@yourdomain.com"

# App URL (used in portal invite links)
NEXT_PUBLIC_APP_URL="https://your-vercel-url.vercel.app"
